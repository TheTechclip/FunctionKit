{
	"name": "@musecat/functionkit",
	"version": "1.3.4",
	"description": "React 19 + TypeScript frontend utility library — hooks, components, datetime, cookie, and utils",
	"keywords": [
		"react",
		"hooks",
		"typescript",
		"utility",
		"frontend"
	],
	"license": "MIT",
	"private": false,
	"author": "Musecat Team",
	"engines": {
		"node": ">=20.0.0"
	},
	"files": [
		"index.ts",
		"packages",
		".agents/",
		"AGENTS.md",
		"CLAUDE.md",
		"README.md",
		"LICENSE"
	],
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "https://github.com/TheTechclip/FunctionKit.git"
	},
	"bugs": {
		"url": "https://github.com/TheTechclip/FunctionKit/issues"
	},
	"homepage": "https://musecat.app",
	"type": "module",
	"main": "./index.ts",
	"types": "./index.ts",
	"exports": {
		".": "./index.ts"
	},
	"scripts": {
		"lint": "biome check",
		"format": "prettier --write . && biome format --write",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@biomejs/biome": "^2.5.4",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.2.0",
		"@testing-library/user-event": "^14.6.1",
		"@vitest/coverage-v8": "^4.1.10",
		"jsdom": "^26.0.0",
		"prettier": "^3.9.5",
		"typescript": "^5.9.3",
		"vitest": "^4.1.10"
	},
	"allowScripts": {
		"esbuild@0.27.7": true
	}
}
